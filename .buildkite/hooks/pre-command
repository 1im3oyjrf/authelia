#!/usr/bin/env bash
# pre-command hook: runs before each command step in the pipeline
# Sets up the environment, configures credentials, and prepares build tools.

set -euo pipefail

echo "--- :buildkite: Pre-command hook starting"

# ── Docker login ────────────────────────────────────────────────────────────
if [[ -n "${DOCKER_USERNAME:-}" && -n "${DOCKER_PASSWORD:-}" ]]; then
  echo "--- :docker: Logging in to Docker Hub"
  echo "${DOCKER_PASSWORD}" | docker login --username "${DOCKER_USERNAME}" --password-stdin
fi

# ── GHCR login ───────────────────────────────────────────────────────────────
if [[ -n "${GHCR_USERNAME:-}" && -n "${GHCR_TOKEN:-}" ]]; then
  echo "--- :github: Logging in to GitHub Container Registry"
  echo "${GHCR_TOKEN}" | docker login ghcr.io --username "${GHCR_USERNAME}" --password-stdin
fi

# ── Go toolchain cache ───────────────────────────────────────────────────────
if command -v go &>/dev/null; then
  GO_VERSION=$(go version | awk '{print $3}')
  echo "--- :go: Go toolchain detected: ${GO_VERSION}"

  # Ensure the module cache directory is writable
  GOPATH="${GOPATH:-${HOME}/go}"
  export GOPATH
  mkdir -p "${GOPATH}/pkg/mod"
fi

# ── Node.js / pnpm setup ─────────────────────────────────────────────────────
if command -v node &>/dev/null; then
  NODE_VERSION=$(node --version)
  echo "--- :nodejs: Node.js detected: ${NODE_VERSION}"
fi

if command -v pnpm &>/dev/null; then
  PNPM_VERSION=$(pnpm --version)
  echo "    pnpm detected: ${PNPM_VERSION}"
fi

# ── Timezone ─────────────────────────────────────────────────────────────────
export TZ="UTC"

# ── Build metadata ───────────────────────────────────────────────────────────
export BUILDKITE_BUILD_AUTHOR_EMAIL="${BUILDKITE_BUILD_AUTHOR_EMAIL:-ci@authelia.com}"

echo "--- :information_source: Build metadata"
echo "    Branch  : ${BUILDKITE_BRANCH:-unknown}"
echo "    Commit  : ${BUILDKITE_COMMIT:-unknown}"
echo "    Pipeline: ${BUILDKITE_PIPELINE_SLUG:-unknown}"
echo "    Step    : ${BUILDKITE_STEP_KEY:-unknown}"

echo "+++ :buildkite: Pre-command hook complete"
